VITE_DROPBOX_APP_KEY=your_dropbox_app_key_here
VITE_DROPBOX_APP_SECRET=your_dropbox_app_secret_here
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ブラウザ単体デプロイ用のみ。デスクトップアプリでは不要（常に FastAPI 経由）。
# server = 認証コード＋バックエンド更新（要 VITE_GOOGLE_CLIENT_SECRET）
# 未設定 = 省略時は implicit（トークンのみ）
# VITE_AUTH_MODE=server
