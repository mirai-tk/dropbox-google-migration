# Copy to .env.desktop and set VITE_* keys (same as web .env).
# 認証モードの切替（VITE_AUTH_MODE）は不要。デスクトップは常に FastAPI 経由。
VITE_DESKTOP=true
VITE_USE_NATIVE_ENGINE=true
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_SECRET=
VITE_DROPBOX_APP_KEY=
VITE_DROPBOX_APP_SECRET=
# Python 側（desktop）: 1GB+ レジュームをオフにして従来に近い転送にする場合（.env または desktop/.env に）
# ENABLE_MIGRATION_RESUME_CHECKPOINTS=0
